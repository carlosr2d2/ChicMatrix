# Database (DBeaver: host=localhost, port=5433)
POSTGRES_USER=chicmatrix
POSTGRES_PASSWORD=chicmatrix
POSTGRES_DB=chicmatrix
DATABASE_URL=postgresql://chicmatrix:chicmatrix@db:5432/chicmatrix

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API
CORS_ORIGINS=http://localhost:3002
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3002
API_BASE_URL=http://localhost:8001
EMAIL_DEBUG=true
CONSENT_VERSION=1.0
SMS_DEBUG=true
OTP_EXPIRE_MINUTES=10
SOCIAL_AUTH_DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
API_INTERNAL_URL=http://backend:8000
NEXT_PUBLIC_SOCIAL_AUTH_DEBUG=true
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=chicmatrix

# Auth (Milestone 2+)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email verification (Milestone 2)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@chicmatrix.app

# SMS / OTP (Milestone 3)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Social login (Milestone 4)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
